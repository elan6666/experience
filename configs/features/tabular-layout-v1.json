{
  "schema_version": "tabular-layout-v1",
  "implementation": "a_share_research.models.tabular.layout:default_feature_layout",
  "ordered_groups": {
    "Core": [
      "open", "high", "low", "close", "volume", "amount", "turnover_rate",
      "return_1d", "return_5d", "return_20d", "volatility_20d", "amount_mean_20d"
    ],
    "F": [
      "pe_ttm", "pb", "ps_ttm", "dv_ttm", "total_mv", "circ_mv", "roe", "roa",
      "grossprofit_margin", "debt_to_assets", "current_ratio", "or_yoy", "netprofit_yoy",
      "ocf_to_or", "assets_turn", "industry_id"
    ],
    "F_missing": [
      "pe_ttm__missing", "pb__missing", "ps_ttm__missing", "dv_ttm__missing",
      "total_mv__missing", "circ_mv__missing", "roe__missing", "roa__missing",
      "grossprofit_margin__missing", "debt_to_assets__missing", "current_ratio__missing",
      "or_yoy__missing", "netprofit_yoy__missing", "ocf_to_or__missing",
      "assets_turn__missing", "industry_id__missing"
    ],
    "S": [
      "csi300_trend_20d", "csi300_volatility_20d", "csi300_turnover_20d",
      "csi300_breadth", "csi300_industry_dispersion", "csi300_liquidity"
    ]
  },
  "gates": {
    "A0": {"Core": 1, "F": 0, "F_missing": 0, "S": 0},
    "A1": {"Core": 1, "F": 1, "F_missing": 1, "S": 0},
    "A2": {"Core": 1, "F": 0, "F_missing": 0, "S": 1},
    "A3": {"Core": 1, "F": 1, "F_missing": 1, "S": 1}
  },
  "mandatory_row_masks": ["member", "observed", "complete_history"],
  "note": "Row masks control coverage outside the model matrix and are never ablated. F missing indicators are part of F and are zero-gated when F is disabled to prevent information leakage."
}
